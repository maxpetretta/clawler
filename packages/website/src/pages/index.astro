---
import "@fontsource-variable/inter/standard.css"
import "@fontsource-variable/inter/standard-italic.css"
import "@/styles/global.css"

const title = "Better Search | Universal web search for OpenClaw"
const description =
  "One OpenClaw tool, eight search providers. Better Search gives your agent access to the best search backends without changing how it works."

const providers = [
  { id: "brave", label: "Brave", category: "search", output: "results", freshness: "Native", domains: "Query rewrite", country: "Native", color: "#fb542b" },
  { id: "exa", label: "Exa", category: "search", output: "results", freshness: "Native", domains: "Native", country: "Prompt", color: "#5b8df9" },
  { id: "tavily", label: "Tavily", category: "hybrid", output: "answer + results", freshness: "Native", domains: "Native", country: "Native", color: "#0bc98c" },
  { id: "parallel", label: "Parallel", category: "search", output: "results", freshness: "Native", domains: "Native", country: "Prompt", color: "#a78bfa" },
  { id: "openai", label: "OpenAI", category: "llm", output: "answer + citations", freshness: "Prompt", domains: "Responses API", country: "Responses API", color: "#19c37d" },
  { id: "anthropic", label: "Anthropic", category: "llm", output: "answer + citations", freshness: "Prompt", domains: "Native", country: "Native", color: "#d4a27f" },
  { id: "perplexity", label: "Perplexity", category: "llm", output: "answer + citations", freshness: "Native", domains: "Native", country: "Prompt", color: "#22b8cf" },
  { id: "gemini", label: "Gemini", category: "llm", output: "answer + citations", freshness: "Prompt", domains: "Prompt", country: "Prompt", color: "#4285f4" },
]

const orbitPositions = [
  { top: "4%", left: "50%" },
  { top: "17%", left: "83%" },
  { top: "50%", left: "96%" },
  { top: "83%", left: "83%" },
  { top: "96%", left: "50%" },
  { top: "83%", left: "17%" },
  { top: "50%", left: "4%" },
  { top: "17%", left: "17%" },
]

const orbitLines = providers.map((p, i) => {
  const angle = (i / 8) * Math.PI * 2 - Math.PI / 2
  return {
    x2: Math.round(350 + 330 * Math.cos(angle)),
    y2: Math.round(350 + 330 * Math.sin(angle)),
    color: p.color,
  }
})

function tagClass(category: string) {
  if (category === "search") return "tag tag-search"
  if (category === "llm") return "tag tag-llm"
  return "tag tag-hybrid"
}

// Syntax highlighting helper — produces HTML with <span> color classes
function highlight(code: string) {
  let html = code
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
  // Comments (must run before string matching)
  html = html.replace(/(\/\/.*)/g, '<span class=hl-comment>$1</span>')
  // JSON keys "key":
  html = html.replace(/"([\w.$\-\/~*]+)"(\s*:)/g, '<span class=hl-key>"$1"</span>$2')
  // Remaining strings "..."
  html = html.replace(/"([^"]*?)"/g, '<span class=hl-string>"$1"</span>')
  // Booleans
  html = html.replace(/\b(true|false)\b/g, '<span class=hl-bool>$1</span>')
  // Numbers after colons
  html = html.replace(/(:\s*)(\d+)/g, '$1<span class=hl-number>$2</span>')
  return html
}

const configCode = highlight(`{
  "plugins": {
    "entries": {
      "better-search": {
        "enabled": true,
        "config": {
          "provider": "auto",
          "fallback": ["perplexity", "brave"],
          "maxResults": 5,
          "cacheTtlMinutes": 15
        }
      }
    }
  },
  "tools": {
    "deny": ["web_search"]
  }
}`)

const toolCallCode = highlight(`// Override the provider for a single query
{
  "query": "latest OpenAI web search docs",
  "provider": "exa",
  "count": 5,
  "freshness": "pm",
  "include_domains": ["platform.openai.com"]
}`)

const installCmd = "openclaw plugin add better-search"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08080a" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site ?? "https://better-search.sh")} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>

  <body>
    <div class="grid-bg" aria-hidden="true"></div>

    <div class="shell">
      <!-- Nav -->
      <nav class="nav">
        <div class="nav-brand">
          <span class="nav-dot" aria-hidden="true"></span>
          Better Search
        </div>
        <div class="nav-links">
          <a href="#providers">Providers</a>
          <a href="#how-it-works">How it works</a>
          <a href="#config">Config</a>
          <a href="https://github.com/maxpetretta/better-search">GitHub</a>
        </div>
      </nav>

      <!-- Hero -->
      <section class="hero">
        <span class="hero-kicker">OpenClaw plugin</span>
        <h1>One search.<br /><em>Every</em> backend.</h1>
        <p class="hero-sub">
          Give your agent access to eight search providers&mdash;from Brave and Exa
          to OpenAI and Anthropic&mdash;through a single tool it already knows how to use.
          No extra setup in your prompts. Just configure once and search.
        </p>
        <div class="hero-actions">
          <div class="install-block">
            <code class="install-cmd" id="install-cmd">{installCmd}</code>
            <button class="install-copy" id="install-copy" type="button" aria-label="Copy install command">
              <svg class="copy-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="5.5" y="5.5" width="8" height="8" rx="1.5" />
                <path d="M10.5 5.5V3.5a1.5 1.5 0 0 0-1.5-1.5H3.5A1.5 1.5 0 0 0 2 3.5V9a1.5 1.5 0 0 0 1.5 1.5h2" />
              </svg>
              <svg class="check-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                <path d="M3 8.5l3.5 3.5 6.5-7" />
              </svg>
            </button>
          </div>
          <a href="https://github.com/maxpetretta/better-search" class="btn btn-ghost">
            GitHub
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 13L13 3M13 3H5M13 3v8" /></svg>
          </a>
        </div>
      </section>

      <!-- Constellation -->
      <section class="constellation" id="providers">
        <p class="constellation-label">Eight providers, one interface</p>

        <div class="orbit-wrap">
          <div class="orbit-ring" aria-hidden="true"></div>
          <div class="orbit-ring-inner" aria-hidden="true"></div>

          <svg class="orbit-lines" viewBox="0 0 700 700" aria-hidden="true">
            {orbitLines.map((line, i) => (
              <line
                x1="350" y1="350"
                x2={line.x2} y2={line.y2}
                class="orbit-line"
                style={`stroke: ${line.color}; opacity: 0.25; animation-delay: ${i * 0.25}s`}
              />
            ))}
          </svg>

          <div class="orbit-center">
            <div class="orbit-center-icon" aria-hidden="true"></div>
            <span class="orbit-center-label">Query</span>
          </div>

          {providers.map((provider, i) => (
            <div
              class="orbit-node"
              style={`top: ${orbitPositions[i].top}; left: ${orbitPositions[i].left}; --node-color: ${provider.color};`}
            >
              <div class="orbit-node-dot">
                {provider.id.slice(0, 2).toUpperCase()}
              </div>
              <span class="orbit-node-label">{provider.label}</span>
              <span class="orbit-node-tag">{provider.category}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- How it works -->
      <section class="section" id="how-it-works">
        <div class="section-intro">
          <h2 class="section-title">How it works</h2>
          <p class="section-desc">
            Better Search sits between your agent and the search providers you already
            have API keys for. It picks the best available backend, runs the search, and
            returns a consistent result&mdash;whether that's a list of links or a full
            answer with citations.
          </p>
        </div>

        <div class="steps">
          <div class="step">
            <div class="step-number">1</div>
            <div class="step-content">
              <h3>Configure your providers</h3>
              <p>Add your API keys and pick a default. Better Search auto-detects which providers are available, or you can set an explicit preference and fallback order.</p>
            </div>
          </div>
          <div class="step-line" aria-hidden="true"></div>
          <div class="step">
            <div class="step-number">2</div>
            <div class="step-content">
              <h3>Your agent searches normally</h3>
              <p>The agent calls one tool&mdash;<code>better_search</code>&mdash;with a query. It never needs to know which provider runs behind the scenes. No prompt changes, no branching logic.</p>
            </div>
          </div>
          <div class="step-line" aria-hidden="true"></div>
          <div class="step">
            <div class="step-number">3</div>
            <div class="step-content">
              <h3>Get normalized results</h3>
              <p>Every provider returns results in the same shape: answers, citations, and links. If the primary provider fails, the fallback chain kicks in automatically.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Provider table -->
      <section class="section" id="provider-matrix">
        <div class="section-intro">
          <h2 class="section-title">Provider matrix</h2>
          <p class="section-desc">
            Some providers return a list of links. Others synthesize an answer with citations.
            Better Search normalizes both into one format so the agent can handle either.
          </p>
        </div>

        <div class="provider-table-wrap">
          <table class="provider-table">
            <thead>
              <tr>
                <th>Provider</th>
                <th>Type</th>
                <th>Output</th>
                <th>Freshness</th>
                <th>Domain filters</th>
                <th>Country</th>
              </tr>
            </thead>
            <tbody>
              {providers.map((p) => (
                <tr>
                  <td class="provider-name">{p.label}</td>
                  <td><span class={tagClass(p.category)}>{p.category}</span></td>
                  <td>{p.output}</td>
                  <td>{p.freshness}</td>
                  <td>{p.domains}</td>
                  <td>{p.country}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Config -->
      <section class="section" id="config">
        <div class="section-intro">
          <h2 class="section-title">Drop-in config</h2>
          <p class="section-desc">
            Set a default provider and optional fallbacks in your OpenClaw config.
            You can also override the provider on any individual search call when a specific
            backend makes more sense for the query.
          </p>
        </div>

        <div class="terminal-wrap">
          <div class="terminal">
            <div class="terminal-bar">
              <span class="terminal-bar-dots" aria-hidden="true">
                <span class="terminal-bar-dot"></span>
                <span class="terminal-bar-dot"></span>
                <span class="terminal-bar-dot"></span>
              </span>
              openclaw.json
            </div>
            <pre><code set:html={configCode} /></pre>
          </div>

          <div class="terminal">
            <div class="terminal-bar">
              <span class="terminal-bar-dots" aria-hidden="true">
                <span class="terminal-bar-dot"></span>
                <span class="terminal-bar-dot"></span>
                <span class="terminal-bar-dot"></span>
              </span>
              tool call
            </div>
            <pre><code set:html={toolCallCode} /></pre>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <footer class="footer">
        <span>Better Search &middot; v0.1.0</span>
        <div class="footer-links">
          <a href="https://github.com/maxpetretta/better-search">GitHub</a>
        </div>
      </footer>
    </div>

    <script>
      const btn = document.getElementById("install-copy")
      const cmd = document.getElementById("install-cmd")
      if (btn && cmd) {
        btn.addEventListener("click", () => {
          navigator.clipboard.writeText(cmd.textContent ?? "").then(() => {
            const copyIcon = btn.querySelector(".copy-icon") as HTMLElement
            const checkIcon = btn.querySelector(".check-icon") as HTMLElement
            if (copyIcon && checkIcon) {
              copyIcon.style.display = "none"
              checkIcon.style.display = "block"
              setTimeout(() => {
                copyIcon.style.display = "block"
                checkIcon.style.display = "none"
              }, 1500)
            }
          })
        })
      }
    </script>
  </body>
</html>
